<% if @case.present? %>
<div class="results" id="query-list-shell" data-controller="query-list"
     data-query-list-query-row-outlet="[data-controller='query-row']"
     data-query-list-case-score-outlet="[data-controller='case-score']"
     data-query-list-sortable-value="<%= @query_list_sortable %>"
     data-action="query-row:scoreChanged->query-list#handleScoreChanged query-row:queryDeleted->query-list#handleQueryDeleted">
  <div class="row">
    <div class="col-sm-12 form-group">
      <div class="float-start">
        <form class="d-flex align-items-center gap-1 me-4"
              data-controller="add-query"
              data-action="submit->add-query#submit">
          <input id="add-query"
                 class="form-control"
                 data-add-query-target="input"
                 placeholder="Add a query to this case"
                 type="text" />
          <input id="add-query-submit"
                 class="btn btn-success"
                 type="submit"
                 value="Add query" />
        </form>
      </div>

      <ul class="list-inline float-end">
        <li class="list-inline-item query-list-toolbar-rated">
          <input type="checkbox"
                 id="show-only-rated-checkbox"
                 class="align-top"
                 data-action="change->query-list#showOnlyRatedChanged"
                 data-query-list-target="showOnlyRatedCheckbox" />
          <a href="#" class="show-only-rated-link"
             data-action="click->query-list#toggleShowOnlyRated">Show only rated</a>
        </li>

        <li class="list-inline-item text-muted"><span class="text-muted"> | </span></li>

        <li class="list-inline-item">
          <a href="#" data-action="click->query-list#runAllSearches">Run all</a>
        </li>

        <li class="list-inline-item text-muted"><span class="text-muted"> | </span></li>

        <li class="list-inline-item">
          <a href="#" data-action="click->query-list#collapseAll">Collapse all</a>
        </li>

        <li class="list-inline-item text-muted"><span class="text-muted"> | </span></li>

        <li class="list-inline-item">
          <span class="text-muted">Sort &nbsp;</span>
          <ul class="list-inline" style="display:inline" role="group" aria-label="sort">
            <% if @query_list_sortable %>
              <li class="list-inline-item">
                <a href="#" class="active"
                   data-action="click->query-list#sortBy"
                   data-query-list-target="sortLink"
                   data-sort="default">
                  Manual
                  <i class="bi bi-arrow-down" aria-hidden="true"></i>
                </a>
              </li>
            <% else %>
              <li class="list-inline-item">
                Manual
                <i class="bi bi-exclamation-triangle text-warning" aria-hidden="true"
                   title="Manual sorting has been disabled by your administrator."></i>
              </li>
            <% end %>
            <li class="list-inline-item"><a href="#" data-action="click->query-list#sortBy" data-query-list-target="sortLink" data-sort="query">Name</a></li>
            <li class="list-inline-item"><a href="#" data-action="click->query-list#sortBy" data-query-list-target="sortLink" data-sort="modified">Modified</a></li>
            <li class="list-inline-item"><a href="#" data-action="click->query-list#sortBy" data-query-list-target="sortLink" data-sort="score">Score</a></li>
            <li class="list-inline-item"><a href="#" data-action="click->query-list#sortBy" data-query-list-target="sortLink" data-sort="error">Errors</a></li>
          </ul>
        </li>
      </ul>

      <div class="clearfix"></div>

      <div class="float-end pe-2">
        Number of Queries: <span data-query-list-target="queryCount"><%= @query_count %></span>
      </div>
      <div class="float-end pe-2">
        <input type="search" placeholder="Filter Queries" aria-label="filter queries"
               class="form-control form-control-sm" id="queries-filter-new"
               data-action="input->query-list#filter"
               data-query-list-target="filterInput" />
      </div>
      <div class="float-end pe-2">
        <i class="frog-icon" aria-hidden="true">&#x1f438;</i>
        <a href="#" data-action="click->frog-report#open">Report</a>
      </div>

      <div class="clearfix"></div>

      <!-- Query rows — IMPORTANT: the <li> markup is duplicated in
           app/javascript/controllers/add_query_controller.js (buildQueryRowHtml).
           Changes here must be mirrored there. -->
      <ul class="results-list-element" data-query-list-target="list">
        <% @queries.each do |query| %>
          <li data-query-list-target="queryRow"
              data-query-id="<%= query.id %>"
              data-query-text="<%= query.query_text %>"
              data-modified-at="<%= query.updated_at.iso8601 %>"
              data-rated="<%= query.ratings.any? %>"
              data-controller="query-row"
              data-query-row-query-id-value="<%= query.id %>"
              data-query-row-query-text-value="<%= query.query_text %>"
              data-query-row-ratings-value="<%= query.ratings.each_with_object({}) { |r, h| h[r.doc_id] = r.rating.to_i }.to_json %>"
              data-query-row-notes-value="<%= query.notes || '' %>"
              data-query-row-information-need-value="<%= query.information_need || '' %>">
            <div class="clearfix">
              <div class="result-header">
                <% if @query_list_sortable %>
                  <span class="drag-handle float-start" title="Drag to reorder">
                    <i class="bi bi-list" aria-hidden="true"></i>
                  </span>
                <% end %>

                <div class="results-score float-start">
                  <div class="overall-rating query-score-badge" data-query-row-target="scoreDisplay">
                    --
                  </div>
                </div>
                <span class="snapshot-query-scores float-start d-none" data-query-row-target="snapshotScores"></span>

                <h2 class="results-title">
                  <span class="query"><%= query.query_text %> &nbsp;</span>
                  <% if query.notes.present? || query.information_need.present? %>
                    <i class="bi bi-chat-left-text text-muted query-notes-indicator"
                       title="Has notes" aria-hidden="true"></i>
                  <% end %>
                </h2>

                <span class="float-end total-results">
                  <small class="text-muted" data-query-row-target="totalResults">
                    <%= query.ratings.size %> rated
                  </small>
                </span>

                <span class="float-end d-none query-row-indicator" title="Hop to it! There are unrated results!"
                      data-query-row-target="frogIndicator">
                  <span class="icon-container">
                    <i class="frog-icon">🐸</i>
                    <span class="notification-bubble" data-query-row-target="frogCount"></span>
                  </span>
                </span>

                <span class="float-end d-none query-row-indicator" title="Querqy rule triggered"
                      data-query-row-target="querqyIndicator">
                  <i class="querqy-icon"></i>
                </span>

                <span class="toggleSign bi bi-chevron-down"
                      data-action="click->query-row#toggle"
                      data-query-row-target="chevron"></span>
              </div>
            </div>

            <div class="sub-results container clearfix d-none"
                 data-query-row-target="expandedContent">
              <%# Toolbar order matches Angular searchResults.html: Score All (aside), then
                  Copy → Toggle Notes → Explain Query + Missing Documents → Set Options → Move + Delete. %>
              <div class="query-row-expanded-toolbar">
                <div class="query-row-score-all">
                  <strong>Score All</strong>
                  <div class="btn-group">
                    <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                            data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="bi bi-check2-square" aria-hidden="true"></i>
                      Score All
                    </button>
                    <ul class="dropdown-menu" data-query-row-target="bulkRateMenu">
                      <li><a class="dropdown-item" href="#"
                             data-action="click->query-row#bulkRate"
                             data-rating-value="clear">Clear All</a></li>
                      <li><hr class="dropdown-divider"></li>
                    </ul>
                  </div>
                </div>

                <div class="btn-toolbar query-row-actions-toolbar" role="toolbar">
                  <div class="btn-group">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#copyQuery"
                            title="Copy query">
                      <i class="bi bi-clipboard" aria-hidden="true"></i>
                    </button>
                  </div>

                  <div class="btn-group">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#toggleNotes">
                      <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                      Toggle Notes
                    </button>
                  </div>

                  <div class="btn-group">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#explainQuery">
                      <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
                      Explain Query
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#openDocFinder">
                      <i class="bi bi-search" aria-hidden="true"></i>
                      Missing Documents
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#toggleDocExplain"
                            data-query-row-target="docExplainToggle"
                            aria-pressed="false"
                            title="Per-document match breakdown (Solr/ES explain in results)">
                      <i class="bi bi-layers" aria-hidden="true"></i>
                      Match breakdown
                    </button>
                  </div>

                  <div class="btn-group">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-action="click->query-row#openQueryOptionsModal">
                      <i class="bi bi-sliders" aria-hidden="true"></i>
                      Set Options
                    </button>
                  </div>

                  <div class="btn-group">
                    <button type="button" class="btn btn-warning btn-sm"
                            data-action="click->query-row#openMoveQueryModal">
                      <i class="bi bi-folder-symlink" aria-hidden="true"></i>
                      Move Query
                    </button>
                    <button type="button" class="btn btn-danger btn-sm"
                            data-action="click->query-row#deleteQuery">
                      <i class="bi bi-trash" aria-hidden="true"></i>
                      Delete Query
                    </button>
                  </div>
                </div>
              </div>

              <div class="query-notes-panel d-none" data-query-row-target="notesPanel">
                <div class="form-group">
                  <label class="form-label">Information Need</label>
                  <input type="text" class="form-control form-control-sm"
                         placeholder="What is the user trying to find?"
                         data-query-row-target="informationNeedInput"
                         value="<%= query.information_need %>" />
                </div>
                <div class="form-group">
                  <label class="form-label">Notes</label>
                  <textarea class="form-control form-control-sm" rows="3"
                            placeholder="Add notes about this query..."
                            data-query-row-target="notesInput"><%= query.notes %></textarea>
                </div>
                <button class="btn btn-primary btn-sm"
                        data-action="click->query-row#saveNotes">
                  Save Notes
                </button>
                <span class="text-success d-none" data-query-row-target="notesSavedIndicator">
                  Saved!
                </span>
              </div>

              <div data-query-row-target="resultsContainer" class="search-results-container">
                <p class="text-muted">Expand to run search.</p>
              </div>
            </div>
          </li>
        <% end %>
      </ul>

      <div data-query-list-target="paginationContainer" class="query-list-pagination"></div>
    </div>
  </div>
</div>

<!-- Shared doc detail modal -->
<div class="modal fade" id="doc-detail-modal" tabindex="-1" aria-labelledby="doc-detail-modal-title" aria-hidden="true"
     data-controller="doc-detail-modal">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="doc-detail-modal-title" data-doc-detail-modal-target="title">Document</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" data-doc-detail-modal-target="body">
      </div>
      <div class="modal-footer">
        <a href="#" target="_blank" rel="noopener" class="btn btn-outline-secondary d-none"
           data-doc-detail-modal-target="viewLink">
          <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> View Document
        </a>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Shared query explain modal -->
<div class="modal fade" id="query-explain-modal" tabindex="-1" aria-labelledby="query-explain-modal-title" aria-hidden="true"
     data-controller="query-explain-modal">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="query-explain-modal-title">Explain Query Parsing</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Details returned from the search engine on how it processed the input query.</p>
        <ul class="nav nav-tabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#qe-tab-params" type="button" role="tab">Params</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#qe-tab-parsing" type="button" role="tab">Parsing</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#qe-tab-template" type="button" role="tab">Query Template</button>
          </li>
        </ul>
        <div class="tab-content mt-2">
          <div class="tab-pane fade show active" id="qe-tab-params" role="tabpanel"
               data-query-explain-modal-target="paramsTab"></div>
          <div class="tab-pane fade" id="qe-tab-parsing" role="tabpanel"
               data-query-explain-modal-target="parsingTab"></div>
          <div class="tab-pane fade" id="qe-tab-template" role="tabpanel"
               data-query-explain-modal-target="templateTab"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary"
                data-action="click->query-explain-modal#copyActive">
          <i class="bi bi-clipboard" aria-hidden="true"></i> Copy
        </button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Shared doc finder modal -->
<div class="modal fade" id="doc-finder-modal" tabindex="-1" aria-labelledby="doc-finder-modal-title" aria-hidden="true"
     data-controller="doc-finder">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="doc-finder-modal-title">Find Missing Documents</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="input-group mb-3">
          <input type="text" class="form-control" placeholder="Search for documents..."
                 data-doc-finder-target="searchInput"
                 data-action="keydown.enter->doc-finder#search" />
          <button class="btn btn-outline-secondary" type="button"
                  data-action="click->doc-finder#search">
            <i class="bi bi-search" aria-hidden="true"></i> Search
          </button>
          <button class="btn btn-outline-secondary" type="button"
                  data-action="click->doc-finder#showRatedDocs">
            All Rated Docs
          </button>
        </div>
        <div data-doc-finder-target="resultsContainer"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Per-query options JSON (parity with Angular Set Options) -->
<div class="modal fade" id="query-options-modal" tabindex="-1" aria-labelledby="query-options-modal-title" aria-hidden="true"
     data-controller="query-options-modal">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="query-options-modal-title">Query options</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small">
          JSON merged into the query when calling the search engine (legacy &ldquo;Set Options&rdquo;).
        </p>
        <textarea class="form-control font-monospace" rows="12" spellcheck="false"
                  data-query-options-modal-target="textarea"></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-action="click->query-options-modal#save">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Move query to another case (parity with Angular Move Query) -->
<div class="modal fade" id="move-query-modal" tabindex="-1" aria-labelledby="move-query-modal-title" aria-hidden="true"
     data-controller="move-query-modal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="move-query-modal-title">Move Query to Another Case</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0" data-move-query-modal-target="loading">Loading cases&hellip;</p>
        <p class="d-none mb-0" data-move-query-modal-target="empty">Please create another case to move this query to first.</p>
        <div class="d-none" data-move-query-modal-target="caseBlock">
          <p class="mb-2">Select a case:</p>
          <div class="list-group" data-move-query-modal-target="caseList" role="list"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-success" disabled
                data-move-query-modal-target="confirmBtn"
                data-action="click->move-query-modal#confirmMove">
          Move to <span data-move-query-modal-target="confirmLabel"></span>
        </button>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
  </div>
</div>
<% end %>
