<% if @case.present? %>
<div id="case-actions" class="row"
     data-controller="snapshot clone-case export-case snapshot-comparison"
     data-snapshot-query-row-outlet="[data-controller='query-row']"
     data-clone-case-case-id-value="<%= @case.id %>"
     data-clone-case-case-name-value="<%= @case.case_name %>"
     data-export-case-case-id-value="<%= @case.id %>"
     data-export-case-case-name-value="<%= @case.case_name %>">
  <div class="col-sm-12">
    <ul class="list-inline">
      <li>
        <span class="glyphicon glyphicon-tasks"></span>
        <a href="#">Select scorer</a>
      </li>
      <li>
        <i class="bi bi-book-half" aria-hidden="true"></i>
        <a href="#">Judgements</a>
      </li>
      <li>
        <span class="glyphicon glyphicon-camera"></span>
        <a href="#" data-action="click->snapshot#open">Create snapshot</a>
      </li>
      <li>
        <i class="bi bi-bar-chart-fill" aria-hidden="true"></i>
        <a href="#" data-action="click->snapshot-comparison#open">Compare snapshots</a>
      </li>
      <li>
        <i class="bi bi-file-earmark-arrow-down" aria-hidden="true"></i>
        <a href="#">Import</a>
      </li>
      <li>
        <span class="glyphicon glyphicon-share-alt" aria-hidden="true"></span>
        <a href="#">Share case</a>
      </li>
      <li>
        <i class="bi bi-copy" aria-hidden="true"></i>
        <a href="#" data-action="click->clone-case#open">Clone</a>
      </li>
      <li>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <a href="#">Delete</a>
      </li>
      <li>
        <i class="bi bi-file-earmark-arrow-up" aria-hidden="true"></i>
        <a href="#" data-action="click->export-case#open">Export</a>
      </li>
      <li id="tune-relevance-link">
        <span class="glyphicon glyphicon-wrench"></span>
        <a href="#" onclick="event.preventDefault()" data-action="click->resizable-pane#toggle">Tune Relevance</a>
      </li>
    </ul>
  </div>

  <!-- Snapshot modal -->
  <div class="modal fade" tabindex="-1" data-snapshot-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <form data-action="submit->snapshot#submit">
          <div class="modal-header">
            <h5 class="modal-title">Take a Snapshot</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>Record the current results and ratings for all queries.
               Useful for comparing future work against this point in time.</p>

            <label for="snapshot-name" class="form-label">Snapshot Name</label>
            <input type="text" class="form-control" id="snapshot-name"
                   data-snapshot-target="nameInput"
                   placeholder="Name your snapshot" required>

            <div class="text-danger mt-2 d-none" data-snapshot-target="errorMessage"></div>
            <div class="text-muted mt-2 d-none" data-snapshot-target="progressMessage">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              Snapshot being created&hellip;
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-snapshot-target="submitButton">
              Take Snapshot
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Clone modal -->
  <div class="modal fade" tabindex="-1" data-clone-case-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <form data-action="submit->clone-case#submit">
          <div class="modal-header">
            <h5 class="modal-title">Clone case: <%= @case.case_name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label for="clone-case-name" class="form-label">New Case Name</label>
              <input type="text" class="form-control" id="clone-case-name"
                     data-clone-case-target="nameInput"
                     placeholder="Enter a name for the cloned case" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Include Case History</label>
              <div class="btn-group d-block" role="group">
                <button type="button" class="btn btn-primary btn-sm"
                        data-clone-case-target="historyToggle"
                        data-history="false"
                        data-action="click->clone-case#toggleHistory">
                  Only include a specific try
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        data-clone-case-target="historyToggle"
                        data-history="true"
                        data-action="click->clone-case#toggleHistory">
                  Include the entire try history
                </button>
              </div>
            </div>

            <div class="mb-3" data-clone-case-target="trySelectGroup">
              <label for="clone-try-select" class="form-label">Select Try</label>
              <select class="form-select" id="clone-try-select" data-clone-case-target="trySelect">
                <% @case.tries.order(try_number: :desc).each do |t| %>
                  <option value="<%= t.try_number %>" <%= 'selected' if t == @try %>>
                    Try <%= t.try_number %><%= " (#{t.name})" if t.name.present? %>
                  </option>
                <% end %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Select Content</label>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="clone-queries" checked
                       data-clone-case-target="cloneQueries">
                <label class="form-check-label" for="clone-queries">Include Queries</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="clone-ratings"
                       data-clone-case-target="cloneRatings">
                <label class="form-check-label" for="clone-ratings">Include Ratings</label>
              </div>
            </div>

            <div class="text-danger d-none" data-clone-case-target="errorMessage"></div>
            <div class="text-muted d-none" data-clone-case-target="progressMessage">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              Cloning case&hellip;
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-clone-case-target="submitButton">
              Clone
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Export modal -->
  <div class="modal fade" tabindex="-1" data-export-case-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <form data-action="submit->export-case#submit">
          <div class="modal-header">
            <h5 class="modal-title">Export Case: <%= @case.case_name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="text-muted">Select an export format. Server-side formats are available below.</p>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="information_need"
                     id="export-information-need" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-information-need">
                <strong>Information Need</strong>
                <small class="text-muted d-block">CSV: query, information_need</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="basic"
                     id="export-basic" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-basic">
                <strong>Basic</strong>
                <small class="text-muted d-block">CSV: query, docid, rating</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="trec"
                     id="export-trec" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-trec">
                <strong>TREC</strong>
                <small class="text-muted d-block">TXT: query_id 0 docno judgment</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="rre"
                     id="export-rre" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-rre">
                <strong>RRE / RankQuest</strong>
                <small class="text-muted d-block">JSON: Rated Ranking Evaluator format</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="ltr"
                     id="export-ltr" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-ltr">
                <strong>LTR (Learning to Rank)</strong>
                <small class="text-muted d-block">TXT: rating qid:queryid # docid query</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="quepid"
                     id="export-quepid" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-quepid">
                <strong>Quepid</strong>
                <small class="text-muted d-block">JSON: complete case for moving between Quepid instances</small>
              </label>
            </div>

            <% if @case.snapshots.any? %>
              <div class="mt-3 d-none" data-export-case-target="snapshotGroup">
                <label for="export-snapshot-select" class="form-label">Snapshot (optional, for unrated pairs)</label>
                <select class="form-select" id="export-snapshot-select" data-export-case-target="snapshotSelect">
                  <option value="">None</option>
                  <% @case.snapshots.order(created_at: :desc).each do |s| %>
                    <option value="<%= s.id %>"><%= s.name %></option>
                  <% end %>
                </select>
              </div>
            <% end %>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-export-case-target="submitButton" disabled>
              Export
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <!-- Snapshot Comparison modal -->
  <div class="modal fade" tabindex="-1" data-snapshot-comparison-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Compare Snapshots</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div data-snapshot-comparison-target="snapshotList"></div>

          <button type="button" class="btn btn-sm btn-outline-primary mt-2 d-none"
                  data-snapshot-comparison-target="addButton"
                  data-action="click->snapshot-comparison#addSnapshot">
            <i class="bi bi-plus"></i> Add Snapshot
          </button>

          <div class="alert alert-warning mt-2 d-none" data-snapshot-comparison-target="warningArea"></div>

          <div class="text-center mt-2 d-none" data-snapshot-comparison-target="loadingSpinner">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            Loading&hellip;
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary"
                  data-snapshot-comparison-target="compareButton"
                  data-action="click->snapshot-comparison#compare" disabled>
            Compare
          </button>
          <button type="button" class="btn btn-outline-secondary d-none"
                  data-snapshot-comparison-target="clearButton"
                  data-action="click->snapshot-comparison#clear">
            Clear Comparison
          </button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>
</div>
<% end %>
