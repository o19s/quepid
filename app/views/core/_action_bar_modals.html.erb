<%# Action bar modals wrapper — the controller scope wraps both the page
    content (yielded) and the modals. Modals sit outside .pane_container
    so they are not trapped by its stacking context (position:fixed +
    overflow on .pane_main creates a context that clips BS5 modal z-index). %>
<% if @case.present? %>
<div data-controller="snapshot clone-case export-case snapshot-comparison delete-case-options import-ratings judgements wizard frog-report"
     data-snapshot-query-row-outlet="[data-controller='query-row']"
     data-frog-report-query-row-outlet="[data-controller='query-row']"
     data-frog-report-case-id-value="<%= @case.id %>"
     data-frog-report-case-name-value="<%= @case.case_name %>"
     data-frog-report-book-id-value="<%= @case.book_id || 0 %>"
     data-frog-report-book-name-value="<%= @case.book&.name || '' %>"
     data-frog-report-queries-count-value="<%= @query_count %>"
     data-wizard-case-id-value="<%= @case.id %>"
     data-wizard-try-number-value="<%= @try&.try_number %>"
     data-wizard-case-name-value="<%= @case.case_name %>"
     data-wizard-show-wizard-value="<%= params[:showWizard] == 'true' %>"
     data-clone-case-case-id-value="<%= @case.id %>"
     data-clone-case-case-name-value="<%= @case.case_name %>"
     data-export-case-case-id-value="<%= @case.id %>"
     data-export-case-case-name-value="<%= @case.case_name %>"
     data-import-ratings-case-id-value="<%= @case.id %>"
     data-judgements-case-id-value="<%= @case.id %>"
     data-judgements-book-id-value="<%= @case.book_id || 0 %>"
     data-judgements-auto-populate-book-pairs-value="<%= @case.auto_populate_book_pairs %>"
     data-judgements-auto-populate-case-judgements-value="<%= @case.auto_populate_case_judgements %>"
     data-judgements-scorer-id-value="<%= @case.scorer_id || 0 %>"
     data-judgements-queries-count-value="<%= @query_count %>"
     data-judgements-teams-value="<%= @case.teams.map { |t| { id: t.id, name: t.name } }.to_json %>"
     data-judgements-books-value="<%= @case.teams.includes(:books).flat_map(&:books).uniq.map { |b| { id: b.id, name: b.name } }.to_json %>"
     data-judgements-query-row-outlet="[data-controller='query-row']">

  <%= yield %>

  <!-- Snapshot modal -->
  <div class="modal fade" tabindex="-1" data-snapshot-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <form data-action="submit->snapshot#submit">
          <div class="modal-header">
            <h5 class="modal-title">Take a Snapshot</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>Record the current results and ratings for all queries.
               Useful for comparing future work against this point in time.</p>

            <label for="snapshot-name" class="form-label">Snapshot Name</label>
            <input type="text" class="form-control" id="snapshot-name"
                   data-snapshot-target="nameInput"
                   placeholder="Name your snapshot" required>

            <div class="text-danger mt-2 d-none" data-snapshot-target="errorMessage"></div>
            <div class="text-muted mt-2 d-none" data-snapshot-target="progressMessage">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              Snapshot being created&hellip;
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-snapshot-target="submitButton">
              Take Snapshot
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Clone modal -->
  <div class="modal fade" tabindex="-1" data-clone-case-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <form data-action="submit->clone-case#submit">
          <div class="modal-header">
            <h5 class="modal-title">Clone case: <%= @case.case_name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label for="clone-case-name" class="form-label">New Case Name</label>
              <input type="text" class="form-control" id="clone-case-name"
                     data-clone-case-target="nameInput"
                     placeholder="Enter a name for the cloned case" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Include Case History</label>
              <div class="btn-group d-block" role="group">
                <button type="button" class="btn btn-primary btn-sm"
                        data-clone-case-target="historyToggle"
                        data-history="false"
                        data-action="click->clone-case#toggleHistory">
                  Only include a specific try
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        data-clone-case-target="historyToggle"
                        data-history="true"
                        data-action="click->clone-case#toggleHistory">
                  Include the entire try history
                </button>
              </div>
            </div>

            <div class="mb-3" data-clone-case-target="trySelectGroup">
              <label for="clone-try-select" class="form-label">Select Try</label>
              <select class="form-select" id="clone-try-select" data-clone-case-target="trySelect">
                <% @case.tries.order(try_number: :desc).each do |t| %>
                  <option value="<%= t.try_number %>" <%= 'selected' if t == @try %>>
                    Try <%= t.try_number %><%= " (#{t.name})" if t.name.present? %>
                  </option>
                <% end %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Select Content</label>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="clone-queries" checked
                       data-clone-case-target="cloneQueries">
                <label class="form-check-label" for="clone-queries">Include Queries</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="clone-ratings"
                       data-clone-case-target="cloneRatings">
                <label class="form-check-label" for="clone-ratings">Include Ratings</label>
              </div>
            </div>

            <div class="text-danger d-none" data-clone-case-target="errorMessage"></div>
            <div class="text-muted d-none" data-clone-case-target="progressMessage">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              Cloning case&hellip;
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-clone-case-target="submitButton">
              Clone
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Export modal -->
  <div class="modal fade" tabindex="-1" data-export-case-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <form data-action="submit->export-case#submit">
          <div class="modal-header">
            <h5 class="modal-title">Export Case: <%= @case.case_name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="text-muted">Select an export format. Server-side formats are available below.</p>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="information_need"
                     id="export-information-need" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-information-need">
                <strong>Information Need</strong>
                <small class="text-muted d-block">CSV: query, information_need</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="basic"
                     id="export-basic" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-basic">
                <strong>Basic</strong>
                <small class="text-muted d-block">CSV: query, docid, rating</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="trec"
                     id="export-trec" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-trec">
                <strong>TREC</strong>
                <small class="text-muted d-block">TXT: query_id 0 docno judgment</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="rre"
                     id="export-rre" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-rre">
                <strong>RRE / RankQuest</strong>
                <small class="text-muted d-block">JSON: Rated Ranking Evaluator format</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="ltr"
                     id="export-ltr" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-ltr">
                <strong>LTR (Learning to Rank)</strong>
                <small class="text-muted d-block">TXT: rating qid:queryid # docid query</small>
              </label>
            </div>

            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="exportFormat" value="quepid"
                     id="export-quepid" data-export-case-target="formatRadio"
                     data-action="change->export-case#selectFormat">
              <label class="form-check-label" for="export-quepid">
                <strong>Quepid</strong>
                <small class="text-muted d-block">JSON: complete case for moving between Quepid instances</small>
              </label>
            </div>

            <% if @case.snapshots.any? %>
              <div class="mt-3 d-none" data-export-case-target="snapshotGroup">
                <label for="export-snapshot-select" class="form-label">Snapshot (optional, for unrated pairs)</label>
                <select class="form-select" id="export-snapshot-select" data-export-case-target="snapshotSelect">
                  <option value="">None</option>
                  <% @case.snapshots.order(created_at: :desc).each do |s| %>
                    <option value="<%= s.id %>"><%= s.name %></option>
                  <% end %>
                </select>
              </div>
            <% end %>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary" data-export-case-target="submitButton" disabled>
              Export
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Case Options modal -->
  <div class="modal fade" tabindex="-1" data-delete-case-options-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Delete Options for Case: <span class="modal-case"><%= @case.case_name %></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>We have a number of options for cleaning up a case, from deleting, to archiving, to deleting all of its queries.</p>

          <div class="btn-group d-flex" role="group">
            <button type="button" class="btn btn-outline-secondary"
                    data-delete-case-options-target="actionButton"
                    data-option-name="delete_all_queries"
                    data-action="click->delete-case-options#selectAction">
              Delete All Queries
            </button>
            <button type="button" class="btn btn-outline-secondary"
                    data-delete-case-options-target="actionButton"
                    data-option-name="archive_case"
                    data-action="click->delete-case-options#selectAction">
              Archive Case
            </button>
            <button type="button" class="btn btn-outline-secondary"
                    data-delete-case-options-target="actionButton"
                    data-option-name="delete_case"
                    data-action="click->delete-case-options#selectAction">
              Delete Case
            </button>
          </div>

          <div class="mt-3">
            <div class="d-none" data-delete-case-options-target="description" data-for-action="delete_all_queries">
              Deleting all the queries will also delete your ratings for those queries.
            </div>
            <div class="d-none" data-delete-case-options-target="description" data-for-action="archive_case">
              You're about to put this case into deep freeze. You'll be able to get to it through "Archived Cases" filter in the Relevancy Cases listing page.
            </div>
            <div class="d-none" data-delete-case-options-target="description" data-for-action="delete_case">
              You're about to delete this case forever! If you think you might want it later, use the Archive function instead.
            </div>
          </div>

          <div class="alert alert-danger mt-2 d-none" data-delete-case-options-target="errorMessage"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" disabled
                  data-delete-case-options-target="confirmButton"
                  data-action="click->delete-case-options#confirm">
            <span data-delete-case-options-target="confirmLabel">Confirm</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Snapshot Comparison modal -->
  <div class="modal fade" tabindex="-1" data-snapshot-comparison-target="modal">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Compare Snapshots</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div data-snapshot-comparison-target="snapshotList"></div>

          <button type="button" class="btn btn-sm btn-outline-primary mt-2 d-none"
                  data-snapshot-comparison-target="addButton"
                  data-action="click->snapshot-comparison#addSnapshot">
            <i class="bi bi-plus"></i> Add Snapshot
          </button>

          <div class="alert alert-warning mt-2 d-none" data-snapshot-comparison-target="warningArea"></div>

          <div class="text-center mt-2 d-none" data-snapshot-comparison-target="loadingSpinner">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            Loading&hellip;
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary"
                  data-snapshot-comparison-target="compareButton"
                  data-action="click->snapshot-comparison#compare" disabled>
            Compare
          </button>
          <button type="button" class="btn btn-outline-secondary d-none"
                  data-snapshot-comparison-target="clearButton"
                  data-action="click->snapshot-comparison#clear">
            Clear Comparison
          </button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Import modal -->
  <div class="modal fade" tabindex="-1" data-import-ratings-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Import into Case: <%= @case.case_name %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#import-ratings-tab"
                      data-import-tab="ratings" data-action="click->import-ratings#selectTab"
                      type="button" role="tab">Ratings</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-bs-toggle="tab" data-bs-target="#import-info-needs-tab"
                      data-import-tab="information_needs" data-action="click->import-ratings#selectTab"
                      type="button" role="tab">Information Needs</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-bs-toggle="tab" data-bs-target="#import-snapshots-tab"
                      data-import-tab="snapshots" data-action="click->import-ratings#selectTab"
                      type="button" role="tab">Snapshots</button>
            </li>
          </ul>

          <div class="tab-content">
            <%# Ratings tab %>
            <div class="tab-pane fade show active" id="import-ratings-tab" role="tabpanel">
              <p>Importing ratings is a great way to manage the rating process outside of Quepid.
                 There are a number of formats for importing this data.</p>

              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="import-clear-queries"
                       data-import-ratings-target="clearQueriesCheckbox">
                <label class="form-check-label" for="import-clear-queries">
                  Clear existing queries?
                  <small class="text-muted">Select to clear all existing queries before importing</small>
                </label>
              </div>

              <p class="mt-3">Select the file format to import:</p>

              <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="importRatingsFormat" value="csv"
                       id="import-csv" data-action="change->import-ratings#selectRatingsFormat">
                <label class="form-check-label" for="import-csv">
                  <strong>CSV</strong>
                  <small class="text-muted d-block">Headers: <code>query,docid,rating</code></small>
                </label>
              </div>

              <div class="mb-3 d-none">
                <input type="file" class="form-control" accept=".csv,text/csv"
                       data-import-ratings-target="ratingsFileInput" data-format="csv"
                       data-action="change->import-ratings#fileSelected">
              </div>

              <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="importRatingsFormat" value="rre"
                       id="import-rre" data-action="change->import-ratings#selectRatingsFormat">
                <label class="form-check-label" for="import-rre">
                  <strong>Rated Ranking Evaluator</strong>
                  <small class="text-muted d-block">JSON: RRE judgement format</small>
                </label>
              </div>

              <div class="mb-3 d-none">
                <input type="file" class="form-control" accept="application/json,.json"
                       data-import-ratings-target="ratingsFileInput" data-format="rre"
                       data-action="change->import-ratings#fileSelected">
              </div>

              <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="importRatingsFormat" value="ltr"
                       id="import-ltr" data-action="change->import-ratings#selectRatingsFormat">
                <label class="form-check-label" for="import-ltr">
                  <strong>Learning to Rank</strong>
                  <small class="text-muted d-block">TXT: <code>rating qid:queryid # docid query</code></small>
                </label>
              </div>

              <div class="mb-3 d-none">
                <input type="file" class="form-control" accept="text/plain,.txt"
                       data-import-ratings-target="ratingsFileInput" data-format="ltr"
                       data-action="change->import-ratings#fileSelected">
              </div>
            </div>

            <%# Information Needs tab %>
            <div class="tab-pane fade" id="import-info-needs-tab" role="tabpanel">
              <p>Importing information needs is the easiest way to update a lot of queries.
                 Export the template file first via the Export feature.</p>

              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="import-create-queries"
                       data-import-ratings-target="createQueriesCheckbox">
                <label class="form-check-label" for="import-create-queries">
                  Create missing queries?
                  <small class="text-muted">Select to create any missing queries from the CSV</small>
                </label>
              </div>

              <p class="mt-2">The CSV file should have the headers: <code>query,information_need</code></p>
              <pre class="bg-light p-2 rounded small">query,information_need
star wars,"The original movie"</pre>

              <div class="mb-3">
                <label class="form-label">Select CSV file to import:</label>
                <input type="file" class="form-control" accept=".csv,text/csv"
                       data-import-ratings-target="informationNeedsFileInput"
                       data-action="change->import-ratings#fileSelected">
              </div>
            </div>

            <%# Snapshots tab %>
            <div class="tab-pane fade" id="import-snapshots-tab" role="tabpanel">
              <p>Importing snapshots lets you bring in a view of search created externally.
                 Any missing queries will be created. The Case ID in the CSV is ignored.</p>

              <p>The CSV file should have the headers:</p>
              <pre class="bg-light p-2 rounded small">Snapshot Name,Snapshot Time,Case ID,Query Text,Doc ID,Doc Position
Legacy Search,10/10/18 18:05,2098,star wars,11,1
Legacy Search,10/10/18 18:05,2098,star wars,1893,2</pre>

              <div class="mb-3">
                <label class="form-label">Select CSV file to import:</label>
                <input type="file" class="form-control" accept=".csv,text/csv"
                       data-import-ratings-target="snapshotFileInput"
                       data-action="change->import-ratings#fileSelected">
              </div>
            </div>
          </div>

          <div data-import-ratings-target="alertArea" class="alert d-none mt-3" role="alert"></div>

          <div class="alert alert-warning mt-2 d-none" data-import-ratings-target="warningArea">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span data-import-ratings-target="warningText">This operation may override existing data. Proceed with caution!</span>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" disabled
                  data-import-ratings-target="submitButton"
                  data-action="click->import-ratings#submit">
            <span data-import-ratings-target="submitText">Import</span>
            <span data-import-ratings-target="spinner" class="spinner-border spinner-border-sm d-none"
                  role="status" aria-hidden="true"></span>
          </button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Judgements modal -->
  <div class="modal fade" tabindex="-1" data-judgements-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Judgements</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Explicit Judgements created by humans and <i class="bi bi-robot"></i> LLMs are a good way
             to start measuring your search quality.</p>
          <p>Quepid organizes Judgements in a <strong>Book</strong> that consists of query and document
             pairs for human evaluation.</p>
          <p><strong>Select a Book below</strong> and configure how data syncs between your Case and Book.</p>

          <%# No teams message %>
          <div class="alert alert-info text-center d-none" data-judgements-target="noTeamsMessage">
            <p>Judgements are meant to be shared with a team, so either
              <a href="<%= teams_path %>">create a new team</a> or share this case with a team first.</p>
          </div>

          <%# No books message %>
          <div class="text-center d-none" data-judgements-target="noBooksMessage">
            <p>You have not created any Books of Judgements yet, so go ahead and create a new Book!</p>
            <a class="btn btn-primary btn-lg" data-judgements-target="createBookLink" href="#">
              <i class="bi bi-plus-lg"></i> Create a book
            </a>
          </div>

          <%# Book list (rendered dynamically by the controller) %>
          <div class="d-none" data-judgements-target="bookList">
            <label class="form-label">Select a Book of Judgements</label>
          </div>

          <%# Select-a-book hint %>
          <div class="alert alert-info mt-3 d-none" data-judgements-target="noBookHint">
            <i class="bi bi-info-circle"></i> Select a book above to configure sync settings.
          </div>

          <%# Integration panel (shown when a book is selected) %>
          <div class="d-none" data-judgements-target="integrationPanel">
            <hr>
            <h6>Case Integration</h6>

            <div class="alert alert-info small">
              <strong>About Book-Case Synchronization:</strong> Books and Cases can share data bi-directionally.
              Your Case provides query/doc pairs to judge, while Book judgements flow back as ratings.
            </div>

            <div class="card">
              <div class="card-body">
                <div class="row align-items-center mb-3">
                  <div class="col-sm-8">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="judgements-auto-populate-pairs"
                             data-judgements-target="autoPopulateBookPairsCheckbox"
                             data-action="change->judgements#toggleSetting">
                      <label class="form-check-label" for="judgements-auto-populate-pairs">
                        Case <i class="bi bi-arrow-right"></i> Book: Query/Doc Pairs
                      </label>
                    </div>
                    <p class="text-muted small mb-0">
                      <strong>On:</strong> New query/doc pairs automatically added to Book when Case runs.<br>
                      <strong>Off:</strong> Manually trigger updates to the Book when needed.
                    </p>
                  </div>
                  <div class="col-sm-4 text-end">
                    <button class="btn btn-outline-secondary btn-sm" disabled
                            data-judgements-target="populateButton"
                            data-action="click->judgements#manualPopulate">
                      <i class="bi bi-box-arrow-up"></i> Populate Now
                    </button>
                  </div>
                </div>

                <hr class="my-2">

                <div class="row align-items-center mb-3">
                  <div class="col-sm-8">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="judgements-auto-populate-judgements"
                             data-judgements-target="autoPopulateCaseJudgementsCheckbox"
                             data-action="change->judgements#toggleSetting">
                      <label class="form-check-label" for="judgements-auto-populate-judgements">
                        Case <i class="bi bi-arrow-left"></i> Book: Judgement Ratings
                      </label>
                    </div>
                    <p class="text-muted small mb-0">
                      <strong>On:</strong> Case ratings update immediately as judgements are made.<br>
                      <strong>Off:</strong> Manually import judgements when ready to test.
                    </p>
                  </div>
                  <div class="col-sm-4 text-end">
                    <button class="btn btn-outline-secondary btn-sm" disabled
                            data-judgements-target="refreshButton"
                            data-action="click->judgements#manualRefresh">
                      <i class="bi bi-box-arrow-in-down"></i> Refresh Ratings
                    </button>
                  </div>
                </div>

                <hr class="my-2">

                <div class="row align-items-center">
                  <div class="col-sm-8">
                    <label class="form-label mb-0">
                      Case <i class="bi bi-arrow-left"></i> Book: Sync missing queries
                    </label>
                    <p class="text-muted small mb-0">Add queries that exist in Book but not in Case.</p>
                  </div>
                  <div class="col-sm-4 text-end">
                    <button class="btn btn-outline-secondary btn-sm" disabled
                            data-judgements-target="syncQueriesButton"
                            data-action="click->judgements#manualSyncQueries">
                      <i class="bi bi-plus-lg"></i> Sync Queries
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="text-danger mt-2 d-none" data-judgements-target="errorMessage"></div>
          <div class="text-muted mt-2 d-none" data-judgements-target="processingMessage">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span></span>
          </div>
        </div>
        <div class="modal-footer">
          <a class="btn btn-primary" data-judgements-target="createBookLink" href="#">
            <i class="bi bi-plus-lg"></i> Create a book
          </a>
          <a class="btn btn-outline-secondary d-none" data-judgements-target="judgeLink" href="#" target="_self">
            <i class="bi bi-book"></i> Judge Documents!
          </a>
          <button class="btn btn-success d-none"
                  data-judgements-target="saveButton"
                  data-action="click->judgements#save">
            Save
          </button>
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Wizard modal -->
  <div class="modal fade" tabindex="-1" data-wizard-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Case Setup Wizard</h5>
        </div>
        <div class="modal-body">

          <%# ── Step 1: Welcome ── %>
          <div data-wizard-target="step">
            <h2>Welcome To Quepid!</h2>
            <img src="/images/doug.jpg" alt="Doug" style="float: left; margin: 20px 30px 100px 20px; width: 100px" />
            <p>Hi, I'm Doug, creator of Quepid. Let me guide you through setting up your very first Case!</p>
            <div class="clearfix"></div>
            <div class="text-end mt-3">
              <button class="btn btn-primary" data-action="click->wizard#nextStep">Continue</button>
            </div>
          </div>

          <%# ── Step 2: Name ── %>
          <div data-wizard-target="step" class="d-none">
            <h2>Name Your Case!</h2>
            <div class="mb-3">
              <label for="wizard-case-name" class="form-label">New Case Name:</label>
              <input type="text" class="form-control" id="wizard-case-name"
                     data-wizard-target="caseNameInput"
                     value="<%= @case.case_name %>" style="max-width: 350px">
            </div>
            <div class="d-flex justify-content-between mt-3">
              <button class="btn btn-outline-secondary" data-action="click->wizard#prevStep">Back</button>
              <button class="btn btn-primary" data-action="click->wizard#nextStep">Continue</button>
            </div>
          </div>

          <%# ── Step 3: Endpoint ── %>
          <div data-wizard-target="step" class="d-none">
            <h2>What Search Endpoint do you want to connect to?</h2>

            <div class="mb-3">
              <div class="btn-group btn-group-sm mb-3" role="group">
                <button type="button" class="btn btn-outline-primary active"
                        data-action="click->wizard#toggleNewEndpoint">Create New</button>
                <button type="button" class="btn btn-outline-primary"
                        data-action="click->wizard#toggleExistingEndpoint">Use Existing</button>
              </div>
            </div>

            <%# ── Create New Endpoint ── %>
            <div data-wizard-target="newEndpointSection">
              <div class="mb-3">
                <label class="form-label fw-bold">Search Engine:</label>
                <div class="row g-2">
                  <% [
                    ["solr", "solr.png", "Solr", "100px"],
                    ["es", "es.png", "Elasticsearch", "150px"],
                    ["os", "os.png", "OpenSearch", "150px"],
                  ].each do |engine, img, label, width| %>
                    <div class="col-auto">
                      <label class="btn btn-outline-secondary p-2">
                        <input type="radio" name="wizard-search-engine" value="<%= engine %>"
                               class="d-none" data-wizard-target="searchEngineRadio"
                               data-action="change->wizard#changeSearchEngine"
                               <%= 'checked' if engine == 'solr' %>>
                        <img src="/images/<%= img %>" alt="<%= label %>" width="<%= width %>">
                      </label>
                    </div>
                  <% end %>
                </div>
                <div class="row g-2 mt-1">
                  <% [
                    ["vectara", "vectara.png", "Vectara", "150px"],
                    ["static", "static.png", "Static", "100px"],
                    ["searchapi", "searchapi.png", "Search API", "100px"],
                  ].each do |engine, img, label, width| %>
                    <div class="col-auto">
                      <label class="btn btn-outline-secondary p-2">
                        <input type="radio" name="wizard-search-engine" value="<%= engine %>"
                               class="d-none" data-wizard-target="searchEngineRadio"
                               data-action="change->wizard#changeSearchEngine">
                        <img src="/images/<%= img %>" alt="<%= label %>" width="<%= width %>">
                      </label>
                    </div>
                  <% end %>
                </div>
                <div class="row g-2 mt-1">
                  <div class="col-auto">
                    <label class="btn btn-outline-secondary p-2">
                      <input type="radio" name="wizard-search-engine" value="algolia"
                             class="d-none" data-wizard-target="searchEngineRadio"
                             data-action="change->wizard#changeSearchEngine">
                      <img src="/images/algolia.png" alt="Algolia" width="150px">
                    </label>
                  </div>
                </div>
              </div>

              <%# URL input (hidden for static) %>
              <div class="mb-3">
                <label for="wizard-search-url" class="form-label">Search URL:</label>
                <div class="input-group">
                  <input type="text" class="form-control" id="wizard-search-url"
                         data-wizard-target="searchUrlInput"
                         data-action="input->wizard#changeSearchUrl"
                         placeholder="http(s?)://yourdomain.com:8983/index/select">
                  <button class="btn btn-outline-primary" type="button"
                          data-wizard-target="validateButton"
                          data-action="click->wizard#validate">ping it</button>
                </div>
                <small class="text-muted d-none" data-wizard-target="urlFormatHint"></small>
              </div>

              <%# Solr-specific panel %>
              <div data-wizard-target="solrPanel">
                <div class="card card-body bg-light mb-3">
                  <div class="row align-items-center">
                    <label class="col-sm-3 form-label mb-0">API Method</label>
                    <div class="col-sm-9">
                      <select class="form-select form-select-sm" data-wizard-target="apiMethodSelect"
                              data-action="change->wizard#changeApiMethod">
                        <option value="JSONP">JSONP</option>
                        <option value="GET">GET</option>
                      </select>
                      <small class="text-muted">Use JSONP if you are talking directly to Solr, otherwise if you are talking to an API you can use GET.</small>
                    </div>
                  </div>
                </div>
              </div>

              <%# Static panel %>
              <div data-wizard-target="staticPanel" class="d-none">
                <div class="card card-body bg-light mb-3">
                  <p>A "Static" (or "Offline") search endpoint is a great way to gather human judgements on queries and search results independent from any live search engine.</p>
                  <p>Create the CSV file with headers: <code>Query Text,Doc ID,Doc Position</code> followed by your document field columns.</p>
                  <input type="file" class="form-control" accept=".csv,text/csv"
                         data-wizard-target="staticFileInput"
                         data-action="change->wizard#uploadStaticCsv">
                </div>
              </div>

              <%# SearchAPI panel %>
              <div data-wizard-target="searchapiPanel" class="d-none">
                <div class="card card-body bg-light mb-3">
                  <h6><i class="bi bi-magic"></i> Custom Mapper Required</h6>
                  <p>Search API endpoints require a custom mapper to translate your API's response format into Quepid's expected format.</p>
                  <button type="button" class="btn btn-primary"
                          data-action="click->wizard#goToMapperWizard">
                    <i class="bi bi-stars"></i> Use Mapper Wizard
                  </button>
                </div>
              </div>

              <%# Advanced panel %>
              <div data-wizard-target="advancedPanel">
                <details class="mb-3">
                  <summary class="btn btn-sm btn-outline-secondary">Advanced</summary>
                  <div class="card card-body mt-2">
                    <div class="mb-2">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="wizard-proxy"
                               data-wizard-target="proxyCheckbox"
                               data-action="change->wizard#changeProxy">
                        <label class="form-check-label" for="wizard-proxy">
                          Proxy Requests
                        </label>
                      </div>
                      <small class="text-muted">Fighting with CORS issues? Proxy your search requests through the Quepid server.</small>
                    </div>

                    <div class="mb-2">
                      <label class="form-label">Basic Authentication</label>
                      <input type="text" class="form-control form-control-sm"
                             data-wizard-target="basicAuthInput"
                             placeholder="username:password">
                      <small class="text-muted">Specify your <code>username:password</code> here.</small>
                    </div>

                    <div class="mb-2">
                      <label class="form-label">Custom Headers (JSON)</label>
                      <textarea class="form-control form-control-sm" rows="3"
                                data-wizard-target="customHeadersInput"
                                placeholder='{ "x-api-key": "YOUR_KEY" }'></textarea>
                    </div>
                  </div>
                </details>
              </div>
            </div>

            <%# ── Use Existing Endpoint ── %>
            <div data-wizard-target="existingEndpointSection" class="d-none">
              <div class="mb-3">
                <label for="wizard-existing-endpoint" class="form-label">Select a Search Endpoint:</label>
                <select class="form-select" id="wizard-existing-endpoint"
                        data-wizard-target="existingEndpointSelect"
                        data-action="change->wizard#changeExistingEndpoint">
                  <option value="">-- Select a search endpoint --</option>
                </select>
                <small class="text-muted">FYI: existing Static File endpoints are NOT shareable across cases.</small>
              </div>

              <%# Test query for SearchAPI %>
              <div data-wizard-target="testQuerySection" class="d-none">
                <div class="card card-body bg-light mb-3">
                  <label class="form-label">Test Query</label>
                  <small class="text-muted d-block mb-2">Enter a test query to validate the endpoint works.</small>
                  <input type="text" class="form-control"
                         data-wizard-target="testQueryInput"
                         data-action="input->wizard#changeTestQuery"
                         placeholder="shirts without stripes">
                </div>
              </div>

              <button class="btn btn-outline-primary" type="button"
                      data-action="click->wizard#validate">ping it</button>
            </div>

            <%# Validation messages %>
            <div class="d-none" data-wizard-target="validationMessage" role="alert"></div>

            <%# TLS protocol mismatch warning %>
            <div class="alert alert-warning mt-2 d-none" data-wizard-target="tlsWarning" role="alert"></div>

            <div class="d-flex justify-content-between mt-3">
              <button class="btn btn-outline-secondary" data-action="click->wizard#prevStep">Back</button>
              <div>
                <button class="btn btn-danger d-none"
                        data-wizard-target="skipValidationButton"
                        data-action="click->wizard#skipValidation">Skip Validation</button>
                <button class="btn btn-primary" disabled
                        data-wizard-target="continueStep3Button"
                        data-action="click->wizard#continueStep3">Continue</button>
              </div>
            </div>
          </div>

          <%# ── Step 4: Fields ── %>
          <div data-wizard-target="step" class="d-none">
            <h2>How Should We Display Your Results?</h2>

            <div class="mb-3">
              <label for="wizard-title-field" class="form-label">Title Field</label>
              <input type="text" class="form-control" id="wizard-title-field"
                     data-wizard-target="titleFieldInput"
                     list="wizard-title-field-list"
                     placeholder="Begin typing to show suggestions">
              <datalist id="wizard-title-field-list" data-wizard-target="titleFieldList"></datalist>
              <small class="text-muted">What field should we treat as the 'title' when displaying results?</small>
            </div>

            <div class="mb-3">
              <label for="wizard-id-field" class="form-label">ID Field</label>
              <input type="text" class="form-control" id="wizard-id-field"
                     data-wizard-target="idFieldInput"
                     list="wizard-id-field-list"
                     placeholder="Begin typing to show suggestions">
              <datalist id="wizard-id-field-list" data-wizard-target="idFieldList"></datalist>
              <small class="text-muted">What field is the unique identifier for your search results?</small>
            </div>

            <div class="mb-3">
              <label class="form-label">Additional Display Fields</label>
              <div class="input-group mb-2">
                <input type="text" class="form-control"
                       data-wizard-target="additionalFieldInput"
                       list="wizard-additional-field-list"
                       placeholder="Add a field (supports media:, thumb:, image: prefixes)"
                       data-action="keydown.enter->wizard#addAdditionalField">
                <datalist id="wizard-additional-field-list" data-wizard-target="additionalFieldList"></datalist>
                <button class="btn btn-outline-secondary" type="button"
                        data-action="click->wizard#addAdditionalField">Add</button>
              </div>
              <div data-wizard-target="additionalFieldsContainer"></div>
              <small class="text-muted">Would any extra fields be handy to display?</small>
            </div>

            <div class="text-danger d-none" data-wizard-target="fieldValidationMessage"></div>

            <div class="d-flex justify-content-between mt-3">
              <button class="btn btn-outline-secondary" data-action="click->wizard#prevStep">Back</button>
              <button class="btn btn-primary" data-action="click->wizard#validateAndContinueStep4">Continue</button>
            </div>
          </div>

          <%# ── Step 5: Queries ── %>
          <div data-wizard-target="step" class="d-none">
            <h2>Add Your Search Queries</h2>
            <p class="text-muted">Start out tuning a couple important search queries:</p>

            <%# Query Pattern for SearchAPI %>
            <div data-wizard-target="queryPatternSection" class="d-none">
              <div class="card card-body bg-light mb-3">
                <label class="form-label fw-bold">Query Pattern</label>
                <small class="text-muted d-block mb-2">
                  Modify your query structure to include <code>#$query##</code> where the search text should be substituted.
                </small>
                <textarea class="form-control" rows="3"
                          data-wizard-target="queryPatternInput"
                          placeholder='{ "query": "#$query##" }'></textarea>
              </div>
            </div>

            <div class="mb-3">
              <div class="input-group">
                <input type="text" class="form-control"
                       data-wizard-target="queryInput"
                       placeholder="Enter a search query"
                       data-action="keydown.enter->wizard#addQuery">
                <button class="btn btn-success btn-sm" type="button"
                        data-action="click->wizard#addQuery">Add Query</button>
              </div>
            </div>

            <div data-wizard-target="queryTagsContainer" class="mb-3"></div>

            <div class="d-flex justify-content-between mt-3">
              <button class="btn btn-outline-secondary" data-action="click->wizard#prevStep">Back</button>
              <button class="btn btn-primary" data-action="click->wizard#continueStep5">Continue</button>
            </div>
          </div>

          <%# ── Step 6: Finish ── %>
          <div data-wizard-target="step" class="d-none">
            <h2>That's It!</h2>
            <p class="text-muted">Go to "Tune Relevance" to iterate on your relevance and manipulate searches.</p>
            <div class="text-end mt-3">
              <button class="btn btn-lg btn-success"
                      data-wizard-target="finishButton"
                      data-action="click->wizard#finish">Finish</button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

  <!-- Frog Pond Report modal -->
  <div class="modal fade" tabindex="-1" data-frog-report-target="modal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">The Frog Pond Report: <span class="text-muted"><%= @case.case_name %></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div>
            <p>The accuracy of the scores calculated by Quepid is directly impacted by the number of &#x1f438;'s you have.
              Chase the frogs into the pond (i.e rate your documents) so that you can have confidence in the changes you are making!</p>

            <h5>Summary</h5>
            <p>
              You have <strong data-frog-report-target="queriesCount"></strong> Queries for this case,
              of which <strong data-frog-report-target="queriesWithResults"></strong> return results,
              and <span data-frog-report-target="queriesWithoutResults"></span> <strong>zero</strong> results.
            </p>
            <p>
              You need to maintain a total of <strong data-frog-report-target="totalRatingsNeeded"></strong> ratings
              to eliminate all the &#x1f438;.
            </p>

            <span data-frog-report-target="allRatedMessage" class="d-none">
              <p class="text-success fw-bold">All the queries have been fully rated! Congratulations!</p>
            </span>

            <span data-frog-report-target="missingRatingsMessage" class="d-none">
              <p>
                There are currently <strong data-frog-report-target="numberOfMissingRatings"></strong> ratings missing,
                leading to <strong data-frog-report-target="missingRatingsRate"></strong>% missing rate.
                We recommend maintaining less than a 5% missing ratings to have confidence in the scores you are calculating.
              </p>
              <p data-frog-report-target="hopToItMessage" class="d-none fw-bold">So hop to it!</p>
            </span>

            <h5 class="mt-4">Distribution of Queries Needing Ratings</h5>
            <div data-frog-report-target="chartContainer" style="min-height: 250px;"></div>
          </div>
        </div>
        <div class="modal-footer">
          <% if @case.book.present? %>
            <button type="button" class="btn btn-outline-secondary"
                    data-frog-report-target="refreshButton"
                    data-action="click->frog-report#refreshRatingsFromBook">
              <span class="spinner-border spinner-border-sm d-none" role="status"
                    data-frog-report-target="refreshSpinner"></span>
              Refresh ratings from book <em><%= @case.book.name %></em>
            </button>
          <% end %>
          <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
          <div class="text-danger mt-2 w-100 d-none" data-frog-report-target="refreshError"></div>
        </div>
      </div>
    </div>
  </div>

</div>
<% else %>
  <%= yield %>
<% end %>
