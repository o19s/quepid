<div class="modal fade" id="pocModal" tabindex="-1" aria-labelledby="pocModalLabel" aria-hidden="true"
     data-controller="poc-modal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-action="poc-modal#cancel" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
        <h4 class="modal-title" data-poc-modal-target="title">POC Modal</h4>
      </div>
      <div class="modal-body">
        <p class="text-muted">
          This modal is powered by Rails + Stimulus. Data was passed in from AngularJS via a CustomEvent.
        </p>

        <div class="form-group">
          <label for="poc-name">Name</label>
          <input type="text" class="form-control" id="poc-name" data-poc-modal-target="nameInput">
        </div>

        <div class="form-group" style="margin-top: 10px;">
          <label for="poc-color">Favorite Color</label>
          <select class="form-control" id="poc-color" data-poc-modal-target="colorSelect">
            <option value="red">Red</option>
            <option value="blue">Blue</option>
            <option value="green">Green</option>
            <option value="purple">Purple</option>
          </select>
        </div>

        <div class="alert alert-success" style="display: none; margin-top: 15px;" data-poc-modal-target="result"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-success" data-action="poc-modal#save">
          Save &amp; Send Back
        </button>
        <button type="button" class="btn btn-default" data-action="poc-modal#cancel">Cancel</button>
      </div>
    </div>
  </div>
</div>
