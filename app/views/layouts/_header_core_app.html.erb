<header id="header" class="navbar-inverse navbar-secondary clearfix">
  <div class="container container-home">
    <div class="navbar-header">
      <%= link_to root_path, class: "navbar-brand", target: "_self" do %>
        Quepid
        <span class="hover"><%= image_tag 'tagline-sm.png', title: "Give your queries some love" %></span>
      <% end %>
    </div>

    <% if current_user.present? %>
      <ul class="navbar-left nav navbar-nav">
        <!-- Begin case selector -->
        <li class="dropdown">
          <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown">
            <span class="nav-label">Relevancy Cases</span>
            <i class="bi bi-chevron-down"></i>
          </a>

          <ul class="dropdown-menu dropdown-content">
            <li class="text-muted">
              <strong>RECENT CASES</strong>
            </li>

            <% @recent_cases.each do |kase| %>
              <li><%= link_to_core_case kase.case_name, kase, kase.last_try_number, class: 'dropdown-link' %></li>
            <% end %>

            <li class="actions">
              <a href="cases" class="btn btn-default btn-block" target="_self">
                View all cases
                <small class="text-muted">
                  (<%= @recent_cases_count %> active)
                </small>
              </a>

              <%= link_to case_new_path, class: "btn btn-success btn-block", target: "_self" do %>
                <i class="bi bi-plus-lg"></i>
                Create a case
              <% end %>
            </li>
          </ul>
        </li>
        <!-- End case selector -->
        <!-- Begin book selector -->
        <li class="dropdown">
          <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown">
            <span class="nav-label">Books</span>
            <i class="bi bi-chevron-down"></i>
          </a>

          <ul class="dropdown-menu dropdown-content">
            <li class="text-muted">
              <strong>RECENT BOOKS</strong>
            </li>

            <% @recent_books.each do |book| %>
              <li><%= link_to book.name, book_path(book), class: 'dropdown-link', target: '_self' %></li>
            <% end %>

            <li class="actions">
              <a href="books" class="btn btn-default btn-block" target="_self">
                View all books
                <small class="text-muted">
                  (<%= @recent_books_count %> active)
                </small>
              </a>

              <%= link_to new_book_path, class: "btn btn-success btn-block", target: "_self" do %>
                <i class="bi bi-plus-lg"></i>
                Create a book
              <% end %>
            </li>
          </ul>
        </li>
        <!-- End book selector -->

        <li><a href="teams" target="_self">Teams</a></li>
        <li><a href="scorers" target="_self">Scorers</a></li>
        <li><a target="_blank" href="notebooks/lab/index.html">Notebooks</a></li>
      </ul>

      <ul class="navbar-right nav navbar-nav">
        <!-- Begin account management dropdown -->
        <li class="dropdown">
          <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown">
            <%= image_tag current_user.avatar_url, size: '24x24', class: 'img-rounded', title: 'Avatar image' %>
            <span data-display-name><%= current_user.display_name %> </span>
            <i class="bi bi-chevron-down"></i>
          </a>

          <ul class="dropdown-menu dropdown-content">
            <li><%= link_to 'My profile', profile_path, class: 'dropdown-link', target: '_self' %></li>
            <li><%= link_to 'Log out', logout_path, class: 'dropdown-link', target: '_self' %></li>
            <li role="separator" class=""></li>
            <li><%= link_to 'API Docs', oas_rails_path, class: 'dropdown-item', target: '_self' %></li>
            <% if current_user.administrator? %>
            <li role="separator" class=""></li>
            <li><%= link_to 'Admin Home', admin_path, class: 'dropdown-link', target: '_self' %></li>
            <li><%= link_to 'Users', admin_users_path, class: 'dropdown-link', target: '_self' %></li>
            <li><%= link_to 'Announcements', admin_announcements_path, class: 'dropdown-item', target: '_self' %></li>
            <li><%= link_to 'Job Manager', mission_control_jobs_path, class: 'dropdown-link', target: '_self' %></li>
            <% end %>
          </ul>
        </li> <!-- End account management -->
      </ul>
      <ul class="navbar-right nav navbar-nav">
        <li>
          <a href='https://quepid-docs.dev.o19s.com/2/quepid' target="_blank">
            User Manual
          </a>
        </li>
        <li>
          <a href='https://github.com/o19s/quepid/wiki' target="_blank">
            Wiki
          </a>
        </li>
      </ul>

    <% end %>
  </div>
</header>
