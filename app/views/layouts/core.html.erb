<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Quepid -- Relevant Search Solved</title>
<%= favicon_link_tag asset_path "favicon.ico" %>
<meta name="description" content="Tired of irrelevant search results? Use Quepid to help improve the quality and relevancy of your search results.">
<meta name="viewport" content="width=device-width">

<%= stylesheet_link_tag 'core', media: 'all' %>
<%= csrf_meta_tags %>
</head>
<body data-quepid-root-url="<%= request.base_url %><%= ENV['RAILS_RELATIVE_URL_ROOT'] %>"
      data-case-id="<%= @case&.id %>"
      data-try-number="<%= @try&.try_number %>"
      data-communal-scorers-only="<%= Rails.application.config.communal_scorers_only %>"
      data-query-list-sortable="<%= Rails.application.config.query_list_sortable %>"
      data-scorer-scale="<%= (@case&.scorer&.scale || []).to_json %>"
      data-scorer-name="<%= @case&.scorer&.name %>"
      data-scorer-id="<%= @case&.scorer&.id %>"
      data-completed-case-wizard="<%= current_user&.completed_case_wizard %>">
  <%# Omit flash_messages here: #main-content passes data-rails-flash to flash_controller (duplicate if header also renders flash). %>
  <%= render 'layouts/header', omit_embedded_flash_messages: true %>

  <div id="main-content"
       data-controller="flash"
       <% if flash.any? %>data-rails-flash="<%= flash.to_hash.to_json %>"<% end %>>
    <div data-flash-target="container"></div>
    <%= yield %>
  </div>

  <%= javascript_importmap_tags 'application_modern' %>

</body>
</html>
